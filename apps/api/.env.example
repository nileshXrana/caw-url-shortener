# .env.example -- Copy to .env and fill in values
# This file documents every environment variable the service needs.
# Variables marked REQUIRED have no default and must be set.
# Variables marked OPTIONAL have a default noted in the comment.

# --- Application ---
NODE_ENV=          # REQUIRED. One of: development, test, staging, production
PORT=              # REQUIRED. Integer. The port the server listens on.

# --- Database ---
DATABASE_URL=      # REQUIRED. Full connection string, e.g. postgres://user:pass@host:5432/db

# --- Redis ---
REDIS_URL=         # REQUIRED. Full connection string, e.g. redis://localhost:6379

# --- Authentication ---
JWT_SECRET=        # REQUIRED. Min 32 characters. Used to sign auth tokens.

# --- CORS ---
CORS_ORIGIN=       # REQUIRED. Allowed origin URL, e.g. http://localhost:3000

# --- Logging ---
LOG_LEVEL=         # OPTIONAL. Default: info. One of: debug, info, warn, error
