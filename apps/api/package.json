{
  "name": "api",
  "version": "0.0.1",
  "description": "Express + TypeScript API for the URL shortener monorepo",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "./node_modules/.bin/prisma generate",
    "build": "./node_modules/.bin/tsc -p tsconfig.build.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "test": "NODE_ENV=test DATABASE_URL=\"postgresql://postgres:postgres@localhost:5432/bootcamp_test?schema=public\" vitest run",
    "test:watch": "NODE_ENV=test DATABASE_URL=\"postgresql://postgres:postgres@localhost:5432/bootcamp_test?schema=public\" vitest",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "axios": "^1.17.0",
    "bullmq": "^5.76.7",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/ioredis": "^4.28.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "prettier": "^3.4.2",
    "supertest": "^7.2.2",
    "tsx": "^4.20.6",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.1.6"
  }
}
